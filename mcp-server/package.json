{
  "name": "world-pnl-card-mcp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Free-hostable MCP server that renders the World PnL result card as a PNG (browserless).",
  "scripts": {
    "dev": "vercel dev",
    "deploy": "vercel --prod",
    "stdio": "node bin/stdio.mjs",
    "test:render": "node scripts/test-render.mjs",
    "test:mcp": "node scripts/test-mcp.mjs",
    "test:stdio": "node scripts/test-stdio.mjs",
    "inspect:stdio": "npx @modelcontextprotocol/inspector node bin/stdio.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@resvg/resvg-js": "^2.6.2",
    "mcp-handler": "^1.0.2",
    "satori": "^0.12.1",
    "zod": "^3.24.1"
  }
}
